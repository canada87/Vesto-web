SECRET_KEY=cambia-questa-stringa-con-qualcosa-di-casuale-e-lungo
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password-sicura

# Durata del token di sessione in giorni (default 7)
JWT_EXPIRE_DAYS=7

# Durata del "dispositivo fidato" per il 2FA in giorni (default 90)
# Dopo questo periodo viene richiesto di nuovo il codice OTP
TRUSTED_DEVICE_EXPIRE_DAYS=90
